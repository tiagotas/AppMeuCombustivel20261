<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMeuCombustivel.MainPage">

    <StackLayout Spacing="10" 
                 Margin="10">
        
        <Label Text="Qual combustível compensa mais? Teste git"
               FontSize="Medium"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />
        
        <Label Text="Informe o preço do Etanol:" />
        <Entry x:Name="etanol" Placeholder="R$ " />
        
        <Label Text="Informe o preço da Gasolina:" />
        <Entry x:Name="gasolina" Placeholder="R$ " />
        
        <Button Text="Calcular" Clicked="Button_Clicked" />
    </StackLayout>

</ContentPage>
